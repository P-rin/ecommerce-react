  "relationships": {
    "users_to_cart": {
      "type": "one_to_many",
      "description": "One user has many cart items (subcollection)",
      "path": "users/{userId}/cart/{cartItemId}"
    },
    "users_to_wishlist": {
      "type": "one_to_many",
      "description": "One user has many wishlist items (subcollection)",
      "path": "users/{userId}/wishlist/{wishlistItemId}"
    },
    "users_to_orders": {
      "type": "one_to_many",
      "description": "One user has many orders (document reference)",
      "field": "orders.userId"
    },
    "products_to_categories": {
      "type": "many_to_one",
      "description": "Many products belong to one category (reference)",
      "field": "products.categoryId"
    },
    "orders_to_products": {
      "type": "many_to_many",
      "description": "Orders contain products (array of items with product references)",
      "field": "orders.items[].productId"
    },
    "cart_to_products": {
      "type": "many_to_many",
      "description": "Cart items reference products",
      "field": "users/{userId}/cart/{cartItemId}.productId"
    },
    "wishlist_to_products": {
      "type": "many_to_many",
      "description": "Wishlist items reference products",
      "field": "users/{userId}/wishlist/{wishlistItemId}.productId"
    }
  },
  "queries": {
    "common_queries": [
      {
        "name": "Get user's cart items",
        "path": "users/{userId}/cart",
        "filters": [],
        "orderBy": "addedAt DESC"
      },
      {
        "name": "Get user's wishlist items",
        "path": "users/{userId}/wishlist",
        "filters": [],
        "orderBy": "addedAt DESC"
      },
      {
        "name": "Get user's orders",
        "path": "orders",
        "filters": ["userId == {userId}"],
        "orderBy": "orderDate DESC"
      },
      {
        "name": "Get products by category",
        "path": "products",
        "filters": ["categoryId == {categoryId}", "isActive == true"],
        "orderBy": "createdAt DESC"
      },
      {
        "name": "Get in-stock products sorted by rating",
        "path": "products",
        "filters": ["inStock == true"],
        "orderBy": "rating.average DESC"
      },
      {
        "name": "Search products by tag",
        "path": "products",
        "filters": ["tags array-contains {tag}", "isActive == true"],
        "orderBy": "rating.average DESC"
      },
      {
        "name": "Get orders by status",
        "path": "orders",
        "filters": ["status == {status}"],
        "orderBy": "orderDate DESC"
      },
      {
        "name": "Get user activity",
        "path": "users/{userId}/userActivity",
        "filters": [],
        "orderBy": "timestamp DESC",
        "limit": "last 50"
      },
      {
        "name": "Get product reviews",
        "path": "products/{productId}/reviews",
        "filters": [],
        "orderBy": "createdAt DESC"
      }
    ]
  },
  "indexes": [
    {
      "collection": "products",
      "fields": [
        {"fieldPath": "categoryId", "order": "ASCENDING"},
        {"fieldPath": "createdAt", "order": "DESCENDING"}
      ]
    },
    {
      "collection": "products",
      "fields": [
        {"fieldPath": "inStock", "order": "ASCENDING"},
        {"fieldPath": "rating.average", "order": "DESCENDING"}
      ]
    },
    {
      "collection": "orders",
      "fields": [
        {"fieldPath": "userId", "order": "ASCENDING"},
        {"fieldPath": "orderDate", "order": "DESCENDING"}
      ]
    },
    {
      "collection": "orders",
      "fields": [
        {"fieldPath": "status", "order": "ASCENDING"},
        {"fieldPath": "orderDate", "order": "DESCENDING"}
      ]
    }
  ]
}
